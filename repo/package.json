{
  "name": "png-website-builders",
  "private": true,
  "scripts": {
    "dev:api": "pnpm --filter @workspace/api-server run dev",
    "dev:web": "pnpm --filter @workspace/sitecraft run dev",
    "build:api": "pnpm --filter @workspace/api-server run build",
    "build:web": "pnpm --filter @workspace/sitecraft run build",
    "typecheck": "pnpm -r run typecheck",
    "db:push": "pnpm --filter @workspace/db run push",
    "db:generate": "pnpm --filter @workspace/db run generate"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "overrides": {}
  },
  "catalog": {
    "@tailwindcss/vite": "^4.1.3",
    "@tanstack/react-query": "^5.70.0",
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.41.0",
    "framer-motion": "^12.7.3",
    "lucide-react": "^0.503.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.2.0",
    "tailwindcss": "^4.1.3",
    "vite": "^6.3.2",
    "zod": "^3.24.2"
  }
}
